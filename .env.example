# Local development environment variables for AutoAPI Phase 2A.
# Copy to .env and adjust as needed. Do not commit real secrets.
#
# Outside Docker Compose, localhost defaults in application.yml apply when these
# are unset. Inside Compose, docker-compose.yml sets postgres service hostnames.

POSTGRES_USER=autoapi
POSTGRES_PASSWORD=autoapi
POSTGRES_DB=autoapi

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/autoapi
SPRING_DATASOURCE_USERNAME=autoapi
SPRING_DATASOURCE_PASSWORD=autoapi
SPRING_R2DBC_URL=r2dbc:postgresql://localhost:5432/autoapi?sslMode=disable
SPRING_R2DBC_USERNAME=autoapi
SPRING_R2DBC_PASSWORD=autoapi
AUTOAPI_CONTROLPLANE_ENABLED=true
AUTOAPI_CONFIG_PATH=deploy/config/runtime.json
