# Local development environment variables for AutoAPI Phase 2A.
# Copy to .env and adjust as needed. Do not commit real secrets.

POSTGRES_USER=autoapi
POSTGRES_PASSWORD=autoapi
POSTGRES_DB=autoapi

AUTOAPI_R2DBC_URL=r2dbc:postgresql://localhost:5432/autoapi
AUTOAPI_JDBC_URL=jdbc:postgresql://localhost:5432/autoapi
AUTOAPI_CONTROLPLANE_ENABLED=true
AUTOAPI_CONFIG_PATH=deploy/config/runtime.json
